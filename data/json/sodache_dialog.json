  {
    "id": 2740275,
    "group": 71002,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "片刻微光吸引了你的视线，你向岩壁深处探去。"
  },
  {
    "id": 2740341,
    "group": 71002,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "但岩层阻挡了你的手指和视线，它们是宝石沉默的守护者。"
  },
  {
    "id": 2740342,
    "group": 71002,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "该做决定了，收获或坍塌只在一瞬之间。"
  },
  {
    "id": 2740276,
    "group": 71003,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "深嵌于岩缝中的黑曜石，光滑的切面，锋利的边缘，看不出岁月的痕迹。"
  },
  {
    "id": 2740343,
    "group": 71003,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "然而包裹它的岩石已被风沙侵蚀。"
  },
  {
    "id": 2740344,
    "group": 71003,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "合适的工具可以让你完整地将它取出。"
  },
  {
    "id": 2740277,
    "group": 71004,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你也无法确定这究竟是流动的石，还是凝住的水。"
  },
  {
    "id": 2740345,
    "group": 71004,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "但你可以察觉它呼吸般的起伏，以及缓缓的、寻找去路般的蠕动。"
  },
  {
    "id": 2740278,
    "group": 71005,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "叮咚咚，叮，叮咚，咚——"
  },
  {
    "id": 2740346,
    "group": 71005,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "它断断续续，忽远忽近，你在头晕目眩之下，突然理解了这支曲子的用意：驱逐。"
  },
  {
    "id": 2740279,
    "group": 71006,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "装饰了一枝枯枝的饰品，颗颗圆润的黑珍珠。"
  },
  {
    "id": 2740347,
    "group": 71006,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你凑近观察，“珍珠”表面的黑影正不断积聚，连同你的倒影一起吞食。"
  },
  {
    "id": 2740280,
    "group": 71007,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一只古旧的匣子，不为任何钥匙所开，只为足量诚意所启。"
  },
  {
    "id": 2740348,
    "group": 71007,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "它要那鲜明的、温暖的、流动的、沉重的诚意。"
  },
  {
    "id": 2740349,
    "group": 71007,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "匣缝中冷光闪烁，正催促你做出选择。"
  },
  {
    "id": 2740281,
    "group": 72002,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "林中光线昏暗，更深处藏着更多未知。"
  },
  {
    "id": 2740350,
    "group": 72002,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你深知无边森林会放大一切虚弱。"
  },
  {
    "id": 2740351,
    "group": 72002,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "若想成功探索、安全撤离，得先补足体力。"
  },
  {
    "id": 2740282,
    "group": 72003,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "藤蔓与缀着宝石的链条紧紧纠缠。宝石耀眼依旧，幽幽绿光，晶莹如糖果。"
  },
  {
    "id": 2740352,
    "group": 72003,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "或许你的行囊里有什么能让它松手的东西。"
  },
  {
    "id": 2740283,
    "group": 72004,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一枚躺在树洞内的红宝石，拳头大小，光芒闪烁。"
  },
  {
    "id": 2740353,
    "group": 72004,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一如生命残存的搏动，或是时代依稀的余音。"
  },
  {
    "id": 2740354,
    "group": 72004,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "这微微收缩的树洞内壁将它包裹，安稳如一处心房。"
  },
  {
    "id": 2740284,
    "group": 72005,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "干硬的叶片互相摩擦，发出近似低语的沙沙声。"
  },
  {
    "id": 2740355,
    "group": 72005,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你看向那束龙舌兰，那属于遗迹的火炬。"
  },
  {
    "id": 2740356,
    "group": 72005,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "若想触碰它，你需得接受遗迹的审视。"
  },
  {
    "id": 2740285,
    "group": 72006,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一把已然老旧的钥匙，布满锈痕，光泽暗淡。"
  },
  {
    "id": 2740357,
    "group": 72006,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "不过，锁在哪儿？"
  },
  {
    "id": 2740286,
    "group": 72007,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一片金叶陈放在石台中央，路过的风也没有将它惊扰。"
  },
  {
    "id": 2740358,
    "group": 72007,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "它的孤独都让你想起了秋天。"
  },
  {
    "id": 2740359,
    "group": 72007,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
