  {
    "id": 2740362,
    "group": 73002,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "——读、前，人……这个人，探索者。你在风中听见窸窣的阅读声。"
  },
  {
    "id": 2740363,
    "group": 73002,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "符号随着你的视线微微发亮，像是也想要辨认你的面庞。"
  },
  {
    "id": 2740289,
    "group": 73003,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "微弱的烛火正在无风处向你摇曳。"
  },
  {
    "id": 2740364,
    "group": 73003,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "它已经无法照亮周围。"
  },
  {
    "id": 2740365,
    "group": 73003,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一点点药剂便可让它重燃活力。"
  },
  {
    "id": 2740290,
    "group": 73004,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "水晶头骨埋于泥土，空洞的眼中闪出微光。"
  },
  {
    "id": 2740366,
    "group": 73004,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "清理尘土便能让你看到它原本的样貌。"
  },
  {
    "id": 2740367,
    "group": 73004,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "在那之前，你需得忍受它恒久的注视。"
  },
  {
    "id": 2740291,
    "group": 73005,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "水晶悬于断枝之上，一次晃动如一次感召。"
  },
  {
    "id": 2740368,
    "group": 73005,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一次次召唤，引来一阵阵躁动。"
  },
  {
    "id": 2740369,
    "group": 73005,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "想要拿到水晶，你最好做足准备，对付这些躁动。"
  },
  {
    "id": 2740292,
    "group": 73006,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "石质发条在残骸中兀自旋转。"
  },
  {
    "id": 2740370,
    "group": 73006,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "咔哒、啪嗒——你听着机关相碰发出的轻微声响。"
  },
  {
    "id": 2740371,
    "group": 73006,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "除此之外，还有些持续不断的嗡嗡低鸣。"
  },
  {
    "id": 2740293,
    "group": 73007,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "旧弹痕围绕于此，如小小祭坛，永远等待下一次供奉。"
  },
  {
    "id": 2740372,
    "group": 73007,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你稍作观察，发现凹槽边缘光滑干净，仿佛经历过无数次嵌入。"
  },
  {
    "id": 2740373,
    "group": 73007,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "祭品是用来换取回报的——现在该你准备“祭品”了。"
  },
  {
    "id": 2740294,
    "group": 74014,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "回信太过快速，令你来不及反应。"
  },
  {
    "id": 2740374,
    "group": 74014,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "如同有人候在门内，只等敲门声响起。"
  },
  {
    "id": 2740375,
    "group": 74014,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "当你读完那些字时，杂音便紧随其后。"
  },
  {
    "id": 2740135,
    "group": 74002011,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一片漆黑中亮起了一双双眼睛，它们覆盖了所有退路。"
  },
  {
    "id": 2740169,
    "group": 87400100,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "眼前是一座极富当地特色的建筑——蠕动的藤蔓爬满了石碑，它们用微小的吸盘啃食着碎岩。一张破碎的纸片藏在建筑下面。你思考着是否应该捡起它——一面是愚昧的安定，一面是那搅乱大脑的知识。"
  },
  {
    "id": 2740170,
    "group": 87400112,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你捡起了它，紧紧地盯着，如远古的司祭紧盯着鲜血淋漓的祭坛一样。你察觉到了从上空滴下的红汁。"
  },
  {
    "id": 2740171,
    "group": 87400122,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "像巨轮下的节肢类捕食者一样逃走吧。命运的重量远非你的瞳孔能够窥视。"
  },
  {
    "id": 2740172,
    "group": 87400130,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "遥远的过去，那些贪图智慧的爬虫在知识搅乱大脑那一刻体验了无穷的欢愉。这稍纵即逝的渴望如同黑夜中的炬火，显眼而又富含希望。这让你忘记了一切的痛苦，伴随而来的危险也被你当作纯情的甘露。"
  },
  {
    "id": 2740173,
    "group": 87400132,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你的同伴惊讶地看着你啃食着这张风化的碎纸，如同嘬饮黄金的蜜，如同撕咬带血的牛肋。你疯狂地想要用手指撕扯脸庞，但是别担心，现在你的外形不过是一台金属机械。所以传到你同伴耳中的也只是尖锐物体划过金属板的刺耳声音。"
  },
  {
    "id": 2740174,
    "group": 87400200,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你品尝着远古的智慧。你的视线逐渐扭曲。那些藤蔓变得更加的骇人。你得到了本不该属于你这种生物的东西。所以有人要来找你收债了。"
  },
  {
    "id": 2740175,
    "group": 87400200,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "伴随着大地深处一次一次如心跳般的震动，一片漆黑中亮起了一双一双眼睛，那血肉的二十二双眼睛都在静静地看着你。扭曲的蚁群悄无声息地逐渐靠近，覆盖了所有的退路。"
  },
  {
    "id": 2740176,
    "group": 87400200,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "这是知识本身的造物，快逃，趁着你们还能走！"
  },
  {
    "id": 2740178,
    "group": 87400300,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "漆黑的雕像伫立在深绿色的树丛中，它平视着不远处的祭坛，像守卫崇拜着太阳。而当你们靠近时，你感觉到雕像似乎在看着你。"
  },
  {
    "id": 2740179,
    "group": 87400300,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "这是一座祭坛，崇拜着一个未知的神明。石台上刻画着这神明的形象——祂有八千目，眼中的光芒赐予大地生机；祂有八千手，手挡住了目光以给予大地荫庇。"
  },
  {
    "id": 2740180,
    "group": 87400300,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你们感到步伐沉重，周围似乎在变得黏稠。你的同伴放下便携装置，打算在此研究一下雕像上的浮雕。"
  },
  {
    "id": 2740181,
    "group": 87400300,
    "order": 4,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "那种眼光更加扎人了，来自不止一座漆黑雕像。不知不觉，你们身边已经围上了许多，细细一数——十六座。并非错觉，它们在慢慢靠近。"
  },
  {
    "id": 2740182,
    "group": 87400300,
    "order": 5,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "这种黏稠与无力……慢慢靠近的雕像……你终于明白，黏稠来源于脑部缺氧，无力来源于失血。你们并非来客，你们只是祭品。"
  },
  {
    "id": 2740183,
    "group": 87400312,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你们打倒了雕像，但是你们逃不出去。冷静下来，灵感在此时颇为重要。"
  },
  {
    "id": 2740185,
    "group": 87400312,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "神明会垂目于献上供奉的人吗？如同你去分辨蚁巢的每一只蚂蚁？或许你也可以不是祭品，而是虔诚的祭祀者。"
  },
  {
    "id": 2740186,
    "group": 87400312,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "祭坛上摆满了破碎的石块，你将你们刚刚用过的绷带丢了上去。阵阵黑烟熏烤着它们。神明似乎非常满意，你感觉到全身都已通灵，也能察觉到觊觎你力量的黑暗。"
  },
  {
    "id": 2740187,
    "group": 87400400,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "眼前有一面破碎的镜子——这是一种在神秘学界经常使用的媒介。许多神秘学家依靠它与另一个维度的眼睛对视。但是这面镜子的古老似乎已经远超玻璃镜被发明的年代，古怪。"
  },
  {
    "id": 2740188,
    "group": 87400400,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你擦了擦镜面，让它显得更光滑一些，然后开始尝试窥视。"
  },
  {
    "id": 2740189,
    "group": 87400400,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "海水在天空之上，而后顺着你的眼睑流下。火焰藏在语言之间，混成滚烫的岩浆流入你的咽喉。"
  },
  {
    "id": 2740190,
    "group": 87400400,
    "order": 4,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "很显然，你看到了你不该看到的东西。但你仍难掩好奇，忍着剧痛再一次看了过去。"
  },
  {
    "id": 2740191,
    "group": 87400400,
    "order": 5,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你听到了千种语言汇集而成的尖锐歌谣，闻到了目之所及一切事物散发出的刺鼻味道。碎裂的骨头声伴随着声带撕裂的低沉呜咽——你已然选择接受那更高维的馈赠。你昏死了过去。"
  },
  {
    "id": 2740192,
    "group": 87400412,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你悠悠转醒，同伴在你看来已经变得古怪，他们在锅里添加着苔藓和泥土，盛出的汤水里混杂着骨头。但是你实在太饿了。"
  },
  {
    "id": 2740193,
    "group": 87400422,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你的无人机轻轻地贴在了食物之上，仿佛你也能靠着它狼吞虎咽——这是生命力迸发的赠礼。这里的神明自古就开始为这片土地赐下繁盛。你感觉到苔藓在你机械的外壳上蔓延，枝蔓从外壳的金属缝隙中钻入。一切都像新生，你觉得好极了。"
  },
  {
    "id": 2740194,
    "group": 87400431,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你拒绝了这种诡异的馈赠，理智让你发觉了可悲的异样。你掀翻了一切，而你的同伴转过了身，你看到藤蔓从他们的眼窝中钻出，从他们的肢体关节钻入。他们的身体已经不再属于他们的灵魂。你该给他们以解脱。"
  },
  {
    "id": 2740195,
    "group": 87400432,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你拼尽全力战胜了他们，安息是这片土地最后的体面。可紧跟着你又发现地上仅有一些破碎的树木——此时，你的同伴一脸关心地看着你。在他们的描述中，你说着奇怪的话，流着泪疯狂地砍击眼前的树木。"
  },
  {
    "id": 2740196,
    "group": 87400432,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "也许你真的疯了？无论如何你都要离开这儿。"
  },
  {
    "id": 2740197,
    "group": 87400500,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你静静地待在营地里，并非是偷懒，而是在执行另外一项工作。他要求今天提交方案。"
  },
  {
    "id": 2740198,
    "group": 87400500,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一个小时过去了，你依旧在修改方案。你的思绪飘向了遗迹内部，不知道你的同伴此刻正在经历什么——诡异的藤蔓或者骇人的血肉，抑或是看得明白但是永远解不明白的谜题？"
  },
  {
    "id": 2740199,
    "group": 87400500,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "不，这解不开的谜题现在正在你的眼前。每一次方案的提交都会得到一份似有似无的回复，然后再根据这个提示接着修改——一般这种事都是在遗迹里发生的……那种让人发毛的低语。就像接下来的这句。"
  },
  {
    "id": 2740200,
    "group": 87400500,
    "order": 4,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "“感觉这次行动还可以再张扬一些，所以海报麻烦设计得更奔放点。但是也别太奔放，也要有一些含蓄的表达，你懂我意思吧？”"
  },
  {
    "id": 2740201,
    "group": 87400512,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "怎么样？低语从来都没从你的耳畔消失。"
  },
  {
    "id": 2740202,
    "group": 87401400,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "距离上一次提交已经过去了数小时，发出的信件犹如你的同伴一般了无音讯。也许是被那些杂乱的恐惧吞吃了？又或者是你再一次叩响了未知的大门。"
  },
  {
    "id": 2740203,
    "group": 87401400,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "随着通讯器“滋啦滋啦”，你的同伴似乎挺过来了，并且准备返程。而反馈也顺着无线电信号一起过来了。是焦头烂额的同伴，还是焦头烂额的你？"
  },
  {
    "id": 2740204,
    "group": 87401400,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "答案是，低语永远是低语。你听着通讯器里同伴的喃喃呓语，仿佛他们的大脑刚刚经历过一场恐惧的撕扯。你看着屏幕里反馈的字字千钧，现在轮到你了。就像那些可怕的注视——一个都跑不掉。"
  },
  {
    "id": 2740205,
    "group": 87401400,
    "order": 4,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "随着无线电的滋啦声，那一头似乎又传来了争吵的声音。看来低语与低语之间并未就你送去的方案达成一致。也许你该选择一种声音倾听，但是你无法判断谁有更高的职级。"
  },
  {
    "id": 2740206,
    "group": 87401400,
    "order": 5,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你的同伴正在聆听远古恐惧的回音，而你则是在等待关乎你是否要加班加点去遗迹中受苦的回音。到底什么才是真正的恐惧？“用第一版吧，你把第一版和第三版融合一下再出个方案给我吧。”"
  },
  {
    "id": 2740207,
    "group": 87400522,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "怎么样？低语从来都没从你的耳畔消失。"
  },
  {
    "id": 2740208,
    "group": 87400522,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "距离上一次提交已经过去了数小时，发出的信件犹如你的同伴一般了无音讯。也许是被那些杂乱的恐惧吞吃了？又或者是你再一次叩响了未知的大门。"
  },
  {
    "id": 2740209,
    "group": 87400522,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "随着通讯器“滋啦滋啦”，你的同伴似乎挺过来了，并且准备返程。而反馈也顺着无线电信号一起过来了。是焦头烂额的同伴，还是焦头烂额的你？"
  },
  {
    "id": 2740210,
    "group": 87400522,
    "order": 4,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "答案是，低语永远是低语。你听着通讯器里同伴的喃喃呓语，仿佛他们的大脑刚刚经历过一场恐惧的撕扯。你看着屏幕里反馈的字字千钧，现在轮到你了。就像那些可怕的注视——一个都跑不掉。"
  },
  {
    "id": 2740211,
    "group": 87400522,
    "order": 5,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "随着无线电的滋啦声，那一头似乎又传来了争吵的声音。看来低语与低语之间并未就你送去的方案达成一致。也许你该选择一种声音倾听，但是你无法判断谁有更高的职级。"
  },
  {
    "id": 2740212,
    "group": 87400522,
    "order": 6,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你的同伴正在聆听远古恐惧的回音，而你则是在等待关乎你是否要加班加点去遗迹中受苦的回音。到底什么才是真正的恐惧？“用第一版吧，你把第一版和第三版融合一下再出个方案给我吧。”"
  },
  {
    "id": 2740213,
    "group": 87400600,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "强烈的光芒扫过天空。你紧闭双目，在透过眼皮的明亮中得见其真身。"
  },
  {
    "id": 2740214,
    "group": 87400612,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "所有的灵魂都将获得宁静，它们将重归土地。号角自山间响起，久久不平息。"
  },
  {
    "id": 2740215,
    "group": 87400622,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "祂灵巧地翻越在树林之间，獠牙啃食着树果，吮吸着赤红的汁液。嘶叫不绝于耳，你亦为振奋。"
  },
  {
    "id": 2740217,
    "group": 87400700,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一个人影在前方蹒跚而行，也许可以靠近一些。"
  },
  {
    "id": 2740218,
    "group": 87400711,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "看着眼前的人形，他全身长满了枝叶与白色的花朵。藤蔓从他的皮肤下生长，花朵在他的眼间盛开。"
  },
  {
    "id": 2740219,
    "group": 87400711,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "他咿咿呜呜，想要找到能够生根的泥土。这里不是满地都是吗？"
  },
  {
    "id": 2740220,
    "group": 87400711,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "抑或所谓的泥土只是另外的肉体？"
  },
  {
    "id": 2740224,
    "group": 87400800,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "象征恶魔的石雕出现在眼前，巨大的嘴巴仿佛要吞吃你的一切。"
  },
  {
    "id": 2740225,
    "group": 87400800,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "如何才能买通一位贪婪的恶魔？"
  },
  {
    "id": 2740226,
    "group": 87400812,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你献上了黄金，将它投入了恶魔的嘴中。金币仿佛受到了高温的炙烤，瞬间化成了液态，最终沿着恶魔雕像的嘴角流了出来。"
  },
  {
    "id": 2740227,
    "group": 87400812,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你可以通过了，但是下一次得带一些不一样的人。"
  },
  {
    "id": 2740228,
    "group": 87400822,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你献上袋中的硕鼠。你看着它翻滚，直至一动不动，随后红液从恶魔雕像的嘴角流出。"
  },
  {
    "id": 2740229,
    "group": 87400822,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你可以通过了，但是下一次得带一些不一样的人。"
  },
  {
    "id": 2740230,
    "group": 87400900,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "一间孤独的小屋，破败且杂乱，像是以前的探险队留下的安全屋。"
  },
  {
    "id": 2740231,
    "group": 87400912,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "屋内空无一人，毫不意外。但是地上却能看到一些人形的黑印。这里肯定发生过什么。"
  },
  {
    "id": 2740232,
    "group": 87400912,
    "order": 2,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你警惕地搜索小屋，从前方传来了一些微弱的信号杂音。滋啦滋啦——"
  },
  {
    "id": 2740233,
    "group": 87400912,
    "order": 3,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你将仪器对向了地上的黑印，而这一瞬间一切杂音都消失一空。一行字仿佛刻在了你的眼球之上。"
  },
  {
    "id": 2740234,
    "group": 87400922,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你不知道这是什么语言，却又能知晓其中奥义。这是古老的歌谣，传送着星空的注视。"
  },
  {
    "id": 2740235,
    "group": 87401000,
    "order": 1,
    "position": 1,
