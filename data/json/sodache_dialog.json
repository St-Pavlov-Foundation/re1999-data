  },
  {
    "id": 2740288,
    "group": 73002,
    "order": 1,
    "position": 1,
    "actor": "多功能观测飞行器",
    "head": "78000001",
    "desc": "你阅读着岩石上古老的符号，一词一句，你艰难地辨认着。"
